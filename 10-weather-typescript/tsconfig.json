{
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./",

    "target": "es2022",
    "module": "nodenext",
    "moduleResolution": "nodenext",

    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,

    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,

    "strict": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "strictPropertyInitialization": false
  }
}